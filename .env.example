# =============================================================================
# Tasker — environment variables
# =============================================================================
# Copy this file to .env.local for local dev, and paste the same keys into
# Vercel → Project → Settings → Environment Variables (Production scope).
#
# Generate a session secret first (one-time, used in both places):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# =============================================================================


# --- Supabase ----------------------------------------------------------------
# Where: Supabase dashboard → Project Settings → API
#   - Project URL  → SUPABASE_URL
#   - service_role secret → SUPABASE_SERVICE_ROLE_KEY  (NEVER expose client-side)
#   - anon public  → SUPABASE_ANON_KEY  (optional in v1; not used yet)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=


# --- Session cookie ----------------------------------------------------------
# 32+ random bytes (base64url). MUST be the same value in dev and prod for the
# same deployment, but different across environments. Rotating this signs every
# user out.
SESSION_SECRET=


# --- Slack OAuth (Sign in with Slack) ----------------------------------------
# Where: api.slack.com/apps → your "Tasker" app → Basic Information
#   - Client ID     → SLACK_CLIENT_ID
#   - Client Secret → SLACK_CLIENT_SECRET
#
# Configure under "OAuth & Permissions":
#   Scopes (User Token Scopes): openid, email, profile
#   Pre-register (don't request yet): users:read, users:read.email, team:read
#   Sprint-2 bot scopes (pre-register): chat:write, commands, im:write, channels:read
#
# Add these as Redirect URLs in the Slack app:
#   http://localhost:3000/api/auth/slack/callback           (dev)
#   https://YOUR-VERCEL-DOMAIN.vercel.app/api/auth/slack/callback   (prod)
#   https://tasker.appycodes.com/api/auth/slack/callback    (custom domain)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/auth/slack/callback


# --- Sentry (optional, T-008) ------------------------------------------------
# Where: sentry.io → Settings → Projects → tasker-web → Client Keys (DSN)
# Both keys can be the same DSN — only NEXT_PUBLIC_SENTRY_DSN is sent to the
# browser. Leave blank to skip Sentry locally.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=


# --- App ---------------------------------------------------------------------
APP_URL=http://localhost:3000
LOG_LEVEL=info
COMMIT_SHA=local
